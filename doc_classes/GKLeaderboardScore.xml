<?xml version="1.0" encoding="UTF-8" ?>
<class name="GKLeaderboardScore" inherits="RefCounted" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/godotengine/godot/master/doc/class.xsd">
	<brief_description>
		Represents a leaderboard score entry.
